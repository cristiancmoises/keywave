# Keywave deployment config. Copy to `.env` (same dir as docker-compose.yml):
#   cp .env.example .env   &&   edit .env
# docker compose reads .env automatically. `.env` is gitignored; this file isn't.

# CORS allowlist. Lock to your real origin in production, e.g.
#   KEYWAVE_ALLOWED_ORIGINS=https://keywave.example.com
KEYWAVE_ALLOWED_ORIGINS=*

# ── TURN (required for reliable video across NAT / mobile / strict firewalls) ──
# Without TURN, calls between two different real networks often fail to connect.
# Enable the bundled coturn with:  docker compose --profile turn up -d --build

# Public hostname or IP that BOTH peers' browsers can reach the TURN server at.
KEYWAVE_TURN_HOST=

# Long random shared secret — generate with:  openssl rand -hex 32
# REQUIRED for the turn profile (coturn refuses to start without it). The same
# value is used by the app to mint matching credentials.
KEYWAVE_TURN_SECRET=

# On a 1:1-NAT cloud VPS (AWS/GCP/Oracle/…), the NIC holds a private IP while the
# public IP is NAT'd. Set the public IP coturn should advertise, or relaying
# silently fails. Use <public-ip>, or <public-ip>/<private-ip> if they differ.
#   public:  curl -s https://ifconfig.me        private: ip route get 1.1.1.1
# Leave blank only on hosts whose public IP is bound directly to the NIC.
KEYWAVE_TURN_EXTERNAL_IP=

# Set to 1 only if you run TURN over TLS on 443 (turns:) with certs on coturn.
# Helps clients on networks that allow only HTTPS egress.
KEYWAVE_TURN_TLS=

# Force ALL media through TURN — use temporarily to verify the relay works.
# KEYWAVE_FORCE_RELAY=1
